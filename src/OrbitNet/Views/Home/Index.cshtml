@model OrbitNet.Models.DashboardViewModel
@{
    ViewData["Title"] = "OrbitNet-NetCore - Dashboard";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <!-- Encabezado -->
            <div class="text-center mb-5">
                <h1 class="display-5 fw-bold text-primary">OrbitNet-NetCore</h1>
                <p class="lead text-muted">Sistema Web de Monitoreo y Simulación de Conexiones Satelitales</p>
                <div class="badge bg-secondary px-3 py-2">Estado: Simulación en Memoria RAM Activa</div>
            </div>

            <!-- Alertas -->
            @if (ViewBag.SuccessMessage != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @ViewBag.SuccessMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (ViewBag.WarningMessage != null)
            {
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @ViewBag.WarningMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-x-circle-fill me-2"></i>
                    @ViewBag.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="row g-4 mb-5">
                <!-- Tarjeta Carga XML -->
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0 rounded-3">
                        <div class="card-header bg-primary text-white py-3">
                            <h5 class="mb-0 fw-semibold">Carga Masiva de Configuración</h5>
                        </div>
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <p class="text-muted small">Seleccione un archivo XML para cargar los satélites ecuatoriales, polares y antenas en memoria RAM.</p>
                            <form asp-action="CargarXml" method="post" enctype="multipart/form-data" class="mt-3">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold text-secondary">Archivo XML (.xml)</label>
                                    <input type="file" name="archivoXml" class="form-control" accept=".xml" required />
                                </div>
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-upload me-2"></i>Procesar Ingesta XML
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Tarjeta Operaciones -->
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0 rounded-3">
                        <div class="card-header bg-dark text-white py-3">
                            <h5 class="mb-0 fw-semibold">Operaciones de Memoria RAM</h5>
                        </div>
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <p class="text-muted small">Limpie la memoria RAM o purgue el historial de auditoría.</p>
                            <div class="d-flex gap-2 flex-column mt-3">
                                <form asp-action="Limpiar" method="post" class="w-100">
                                    <button type="submit" class="btn btn-outline-danger w-100 text-start">
                                        <i class="bi bi-trash-fill me-2"></i>Purgar Memoria RAM
                                    </button>
                                </form>
                                <form asp-action="LimpiarLogs" method="post" class="w-100">
                                    <button type="submit" class="btn btn-outline-warning w-100 text-start">
                                        <i class="bi bi-journal-x me-2"></i>Purgar Historial de Logs
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabla Satélites Ecuatoriales -->
            <div class="card shadow-sm border-0 rounded-3 overflow-hidden mb-4">
                <div class="card-header bg-primary text-white px-4 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-semibold">Satélites Ecuatoriales en Memoria</h5>
                    <span class="badge bg-light text-dark rounded-pill px-3">@Model.SatelitesEcu.Tamano Elementos</span>
                </div>
                <div class="card-body p-4 bg-light">
                    @if (Model.SatelitesEcu.EstaVacia)
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-folder-x display-4 text-secondary mb-3 d-block"></i>
                            <p class="mb-0">No hay satélites ecuatoriales en memoria RAM.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 bg-white rounded-3 overflow-hidden shadow-sm">
                                <thead class="table-dark text-uppercase fs-6">
                                    <tr>
                                        <th scope="col" class="px-4 py-3 text-secondary">ID Satélite</th>
                                        <th scope="col" class="py-3 text-secondary">Nombre</th>
                                        <th scope="col" class="py-3 text-secondary">Dirección IP</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var actualEcu = Model.SatelitesEcu.ObtenerCabeza();
                                        while (actualEcu != null)
                                        {
                                            <tr>
                                                <td class="px-4 py-3 font-monospace fw-bold text-primary">@actualEcu.Ecuatorial.Id</td>
                                                <td class="py-3 fw-semibold text-dark">@actualEcu.Ecuatorial.Nombre</td>
                                                <td class="py-3">
                                                    <span class="badge bg-light text-dark font-monospace border px-2 py-1">
                                                        @actualEcu.Ecuatorial.EnlaceIP
                                                    </span>
                                                </td>
                                            </tr>
                                            actualEcu = actualEcu.Siguiente;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- Tabla Satélites Polares -->
            <div class="card shadow-sm border-0 rounded-3 overflow-hidden mb-4">
                <div class="card-header bg-info text-white px-4 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-semibold">Satélites Polares en Memoria</h5>
                    <span class="badge bg-light text-dark rounded-pill px-3">@Model.SatelitesPol.Tamano Elementos</span>
                </div>
                <div class="card-body p-4 bg-light">
                    @if (Model.SatelitesPol.EstaVacia)
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-folder-x display-4 text-secondary mb-3 d-block"></i>
                            <p class="mb-0">No hay satélites polares en memoria RAM.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 bg-white rounded-3 overflow-hidden shadow-sm">
                                <thead class="table-dark text-uppercase fs-6">
                                    <tr>
                                        <th scope="col" class="px-4 py-3 text-secondary">Polar ID</th>
                                        <th scope="col" class="py-3 text-secondary">Satélite ID</th>
                                        <th scope="col" class="py-3 text-secondary">Nombre</th>
                                        <th scope="col" class="py-3 text-secondary">Frecuencia</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var actualPol = Model.SatelitesPol.ObtenerCabeza();
                                        while (actualPol != null)
                                        {
                                            <tr>
                                                <td class="px-4 py-3 font-monospace fw-bold text-info">@actualPol.Polar.PolarID</td>
                                                <td class="py-3 font-monospace text-dark">@actualPol.Polar.SateliteID</td>
                                                <td class="py-3 fw-semibold text-dark">@actualPol.Polar.Nombre</td>
                                                <td class="py-3">
                                                    <span class="badge bg-light text-dark font-monospace border px-2 py-1">
                                                        @actualPol.Polar.Frecuencia MHz
                                                    </span>
                                                </td>
                                            </tr>
                                            actualPol = actualPol.Siguiente;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- Tabla Antenas Terrestres -->
            <div class="card shadow-sm border-0 rounded-3 overflow-hidden mb-4">
                <div class="card-header bg-success text-white px-4 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-semibold">Antenas Terrestres en Memoria</h5>
                    <span class="badge bg-light text-dark rounded-pill px-3">@Model.Antenas.Tamano Elementos</span>
                </div>
                <div class="card-body p-4 bg-light">
                    @if (Model.Antenas.EstaVacia)
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-folder-x display-4 text-secondary mb-3 d-block"></i>
                            <p class="mb-0">No hay antenas terrestres en memoria RAM.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 bg-white rounded-3 overflow-hidden shadow-sm">
                                <thead class="table-dark text-uppercase fs-6">
                                    <tr>
                                        <th scope="col" class="px-4 py-3 text-secondary">ID Antena</th>
                                        <th scope="col" class="py-3 text-secondary">Nombre</th>
                                        <th scope="col" class="py-3 text-secondary">Coordenadas</th>
                                        <th scope="col" class="py-3 text-secondary">IP Nodo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var actualAnt = Model.Antenas.ObtenerCabeza();
                                        while (actualAnt != null)
                                        {
                                            <tr>
                                                <td class="px-4 py-3 font-monospace fw-bold text-success">@actualAnt.Antena.IdAntena</td>
                                                <td class="py-3 fw-semibold text-dark">@actualAnt.Antena.Nombre</td>
                                                <td class="py-3 font-monospace text-muted">@actualAnt.Antena.Coordenadas</td>
                                                <td class="py-3">
                                                    <span class="badge bg-light text-dark font-monospace border px-2 py-1">
                                                        @actualAnt.Antena.IpNodo
                                                    </span>
                                                </td>
                                            </tr>
                                            actualAnt = actualAnt.Siguiente;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- Tabla Logs -->
            <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
                <div class="card-header bg-secondary text-white px-4 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-semibold">Bitácora de Auditoría (LogAuditoria)</h5>
                    <span class="badge bg-light text-dark rounded-pill px-3">@Model.Logs.Tamano Eventos</span>
                </div>
                <div class="card-body p-4 bg-light">
                    @if (Model.Logs.EstaVacia)
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-journal-x display-4 text-secondary mb-3 d-block"></i>
                            <p class="mb-0">No hay eventos registrados en la bitácora.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 bg-white rounded-3 overflow-hidden shadow-sm">
                                <thead class="table-dark text-uppercase fs-6">
                                    <tr>
                                        <th scope="col" class="px-4 py-3 text-secondary">Timestamp</th>
                                        <th scope="col" class="py-3 text-secondary">Tipo</th>
                                        <th scope="col" class="py-3 text-secondary">Mensaje</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var actualLog = Model.Logs.ObtenerCabeza();
                                        while (actualLog != null)
                                        {
                                            <tr>
                                                <td class="px-4 py-3 font-monospace text-muted small">
                                                    @actualLog.Dato.FechaHora.ToString("yyyy-MM-dd HH:mm:ss")
                                                </td>
                                                <td class="py-3">
                                                    @if (actualLog.Dato.Tipo == "ERROR")
                                                    {
                                                        <span class="badge bg-danger">ERROR</span>
                                                    }
                                                    else if (actualLog.Dato.Tipo == "ALERTA")
                                                    {
                                                        <span class="badge bg-warning text-dark">ALERTA</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-success">INFO</span>
                                                    }
                                                </td>
                                                <td class="py-3 text-dark">@actualLog.Dato.Mensaje</td>
                                            </tr>
                                            actualLog = actualLog.Siguiente;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>